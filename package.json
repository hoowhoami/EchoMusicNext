{
  "name": "echo-music-next",
  "version": "1.0.0",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build && electron-builder",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.ts,.jsx,.tsx --fix",
    "format": "prettier --write \"src/**/*.{vue,ts,js,json}\" \"vite.config.ts\" \"tsconfig*.json\""
  },
  "dependencies": {
    "@iconify/icons-tabler": "^1.2.95",
    "@iconify/types": "^2.0.0",
    "@iconify/vue": "^5.0.0",
    "@vueuse/core": "^14.2.1",
    "axios": "^1.13.6",
    "conf": "^15.1.0",
    "electron-log": "^5.4.3",
    "howler": "^2.2.4",
    "pinia": "^2.3.1",
    "pinia-plugin-persistedstate": "^4.2.0",
    "reka-ui": "^2.9.2",
    "sortablejs": "^1.15.7",
    "vue": "^3.5.30",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/howler": "^2.2.12",
    "@types/node": "^22.13.9",
    "@types/sortablejs": "^1.15.9",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "autoprefixer": "^10.4.27",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.8.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.7.3",
    "vite": "^6.2.0",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vue-tsc": "^2.2.8"
  },
  "build": {
    "appId": "com.hoowhoami.echomusicnext",
    "productName": "EchoMusic",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "extraResources": [
      {
        "from": "build/icons",
        "to": "icons",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "server",
        "to": "server",
        "filter": [
          "**/*",
          "!node_modules"
        ]
      }
    ],
    "mac": {
      "icon": "build/icons/icon.icns",
      "category": "public.app-category.music",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icons/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "icon": "build/icons",
      "target": [
        "AppImage",
        "deb",
        "rpm",
        "tar.gz"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-${version}-Windows-Setup-${arch}.${ext}"
    },
    "dmg": {
      "artifactName": "${productName}-${version}-macOS.${ext}"
    },
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller"
    ],
    "ignoredBuiltDependencies": [
      "electron",
      "esbuild",
      "vue-demi"
    ]
  }
}
